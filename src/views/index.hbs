<div id="worksExperience"></div>
<h1 class="h1Title">Works Experience :</h1>

<div class="workExperiencesContainer">
    {{#each workExperiences}}
    <div class="workCard">
        <div class="corporation">
        <img src="{{image}}" alt="placeholder" class="workImage">
        <div class="textArea">
            <h2>{{role}}</h2>
            <h3>{{name}}</h3>
            {{#each task}}
                <li>{{this}}</li>
            {{/each}}
        </div>
        </div>
        
        <div class="workingTimeArea">
            <h5>{{time}}</h5>
        </div>
    </div>
    {{/each}}
</div>

<div id="myProjects"></div>
<h1 class="h1Title">My projects</h1>

<div class="myProjects">
<div class="projectsContainer">
    {{#each myProjects}}
    <div class="projectsCard">
        <img src="{{image}}" alt="placeholder" class="projectImage">
        <div class="projectIntro">
            <div class="projectIntroText">
            <p>{{description}}</p>
            </div>
        </div>
        <div class="projectTagsContainer">
            {{#each tag}}
                <div class="projectTags">
                    {{this}}
                </div>
            {{/each}}
        </div>
        <div class="projectButtonArea">
        <a href="{{githubLink}}"><button class="toGithub">To this project github</button></a>
        </div>
    </div>
    {{/each}}
</div>
</div>

